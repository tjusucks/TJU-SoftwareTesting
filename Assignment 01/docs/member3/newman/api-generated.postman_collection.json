                  "const body = pm.response.json();",
                  "pm.test('token returned', function () { pm.expect(body.user.token).to.be.a('string').and.not.empty; });",
                  "pm.environment.set('token', body.user.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"user\":{\"email\":\"{{EMAIL}}\",\"password\":\"{{PASSWORD}}\"}}"
            },
            "url": "{{APIURL}}/users/login"
          }
        },
        {
          "name": "TC-005 R2 Reject invalid login credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('wrong password rejected', function () { pm.expect([401, 422]).to.include(pm.response.code); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"user\":{\"email\":\"{{EMAIL}}\",\"password\":\"wrongpassword\"}}"
            },
            "url": "{{APIURL}}/users/login"
          }
        },
        {
          "name": "TC-006 R2 Reject malformed login payload",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('malformed login rejected', function () { pm.expect([400, 401, 422]).to.include(pm.response.code); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"{{EMAIL}}\"}" },
            "url": "{{APIURL}}/users/login"
          }
        },
        {
          "name": "TC-008 R3 Reject current user access without token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('missing token rejected', function () { pm.expect([401, 403]).to.include(pm.response.code); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{APIURL}}/user"
          }
        },
        {
          "name": "TC-007 R3 Get current user with valid token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('authorized current user succeeds', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('current user matches registration email', function () { pm.expect(body.user.email).to.eql(pm.environment.get('EMAIL')); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{APIURL}}/user"
          }
        },
        {
          "name": "TC-009 R3 Update current user and persist supported fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('update succeeds', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "const body = pm.response.json();",
                  "pm.test('bio updated', function () { pm.expect(body.user.bio).to.eql(pm.environment.get('BIO')); });",
                  "pm.test('image updated', function () { pm.expect(body.user.image).to.eql(pm.environment.get('IMAGE')); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"user\":{\"bio\":\"{{BIO}}\",\"image\":\"{{IMAGE}}\"}}"
            },
            "url": "{{APIURL}}/user"
          }
        }
      ]
    },
    {
      "name": "Articles and Social",
