          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"article\":{\"title\":\"member3 article {{uid}}\",\"description\":\"desc\",\"body\":\"body\"}}"
