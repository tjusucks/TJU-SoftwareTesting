{
  "info": {
    "name": "member3-generated-api-tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Generated from docs/member3/generated-blackbox-output-v1.md and aligned with SKILL2. Covers RealWorld API cases R1-R8 with traceable request names."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('uid')) {",
          "  const uid = String(Date.now());",
          "  pm.environment.set('uid', uid);",
          "  pm.environment.set('USERNAME', `member3_user_${uid}`);",
          "  pm.environment.set('EMAIL', `member3_${uid}@example.com`);",
          "  pm.environment.set('SECOND_USERNAME', `member3_other_${uid}`);",
          "  pm.environment.set('SECOND_EMAIL', `member3_other_${uid}@example.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth and User",
      "item": [
        {
          "name": "TC-001 R1 Register new user successfully",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is success', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "const body = pm.response.json();",
                  "pm.test('user object returned', function () { pm.expect(body).to.have.property('user'); });",
                  "pm.test('token returned', function () { pm.expect(body.user.token).to.be.a('string').and.not.empty; });",
                  "pm.environment.set('token', body.user.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"user\":{\"email\":\"{{EMAIL}}\",\"password\":\"{{PASSWORD}}\",\"username\":\"{{USERNAME}}\"}}"
            },
            "url": "{{APIURL}}/users"
          }
        },
        {
          "name": "TC-002 R1 Reject duplicate username on registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('duplicate username rejected', function () { pm.expect([409, 422]).to.include(pm.response.code); });",
                  "const body = pm.response.json();",
                  "pm.test('no success token returned', function () { pm.expect(body.user).to.equal(undefined); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"user\":{\"email\":\"duplicate_{{uid}}@example.com\",\"password\":\"{{PASSWORD}}\",\"username\":\"{{USERNAME}}\"}}"
            },
            "url": "{{APIURL}}/users"
          }
        },
        {
          "name": "TC-003 R1 Reject duplicate email on registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('duplicate email rejected', function () { pm.expect([409, 422]).to.include(pm.response.code); });",
                  "const body = pm.response.json();",
                  "pm.test('no success token returned', function () { pm.expect(body.user).to.equal(undefined); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"user\":{\"email\":\"{{EMAIL}}\",\"password\":\"{{PASSWORD}}\",\"username\":\"duplicate_email_{{uid}}\"}}"
            },
            "url": "{{APIURL}}/users"
          }
        },
        {
          "name": "TC-004 R2 Login with valid credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
