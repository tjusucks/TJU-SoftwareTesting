        {
          "name": "TC-010 R4 Create article successfully",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('article create succeeds', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "const body = pm.response.json();",
                  "pm.environment.set('slug', body.article.slug);",
                  "pm.test('article has slug', function () { pm.expect(body.article.slug).to.be.a('string').and.not.empty; });"
                ]
